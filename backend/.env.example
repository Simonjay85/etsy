# ── App ─────────────────────────────────────────────────────
APP_NAME=CV Studio
APP_ENV=development        # development | production
SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cvstudio:cvstudio@localhost:5432/cvstudio

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ──────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | r2
STORAGE_PATH=./storage

# Cloudflare R2 (fill when using r2)
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cvstudio

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Etsy API ─────────────────────────────────────────────────
ETSY_API_KEY=
ETSY_API_SECRET=
ETSY_REDIRECT_URI=http://localhost:8000/auth/etsy/callback

# ── LibreOffice ──────────────────────────────────────────────
# Path to soffice binary (auto-detected if in PATH)
LIBREOFFICE_PATH=soffice

# ── Celery ───────────────────────────────────────────────────
CELERY_TASK_TIMEOUT=300        # seconds
MAX_BATCH_SIZE=50              # max files per batch job
